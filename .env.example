# [Required] The base URL for the OpenAI-compatible LLM server.
LLM_BASE_URL=http://localhost:1234/v1

# [Required] The API key for the LLM server.
LLM_API_KEY=nokey

# [Required] The underlying model to use.
LLM_MODEL=google/gemma-4-e4b

# [Optional] Embeddings model. Falls back to LLM_MODEL if unset.
# Set this when your embeddings model differs from your chat model (common case).
# EMBED_MODEL=nomic-embed-text

# [Optional] Path to a custom CA bundle (.crt / .pem). Leave unset to use system default.
# CA_BUNDLE_PATH=./custom-ca.crt

# [Optional] Vector store backend. Supported values: sqlite (default), qdrant.
# VECTOR_BACKEND=sqlite

# [Optional] SQLite database path for the sqlite-vec backend. Unset = in-memory (lost on restart).
# SQLITE_PATH=./data/vectors.db

# [Optional] Shared vector size for all backends. Must match your embedding model's output dimension.
# VECTOR_SIZE=768

# [Optional] Qdrant collection name (qdrant backend only).
# QDRANT_COLLECTION=knowledge_base

# [Optional] Local persistent storage path for Qdrant. Unset = in-memory.
# QDRANT_PATH=./data/qdrant

# [Optional] Remote Qdrant cluster URL. Takes precedence over QDRANT_PATH.
# QDRANT_URL=http://localhost:6333
# OIDC_CLIENT_ID=chat-agent

# [Optional] OAuth2 client secret.
# OIDC_CLIENT_SECRET=chat-agent-secret

# [Optional] Full URL to the provider's OpenID Connect discovery document.
# OIDC_DISCOVERY_URL=http://localhost:5556/dex/.well-known/openid-configuration

# [Optional] Callback URL registered with the provider. Defaults to http://127.0.0.1:8080/auth/callback.
# OIDC_REDIRECT_URI=http://127.0.0.1:8080/auth/callback

# [Optional] JWT claim that carries role strings. Defaults to "roles".
# OIDC_ROLES_CLAIM=roles

# [Optional] Memory MCP server path. Defaults to in-memory (lost on server restart).
# MEMORY_PATH=./data/memory.json